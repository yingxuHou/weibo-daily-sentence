# Environment
ENV=development

# Database
# Local development:
DATABASE_URL=mysql+pymysql://root:password@localhost:3306/weibo_daily
# Zeabur deployment (use service reference):
# DATABASE_URL=${MYSQL_URL}
# Or manual Zeabur MySQL connection:
# DATABASE_URL=mysql+pymysql://root:password@mysql.zeabur.internal:3306/zeabur?charset=utf8mb4
DB_ECHO=True

# Redis
REDIS_URL=redis://localhost:6379/0

# Weibo API
WEIBO_APP_KEY=your_app_key_here
WEIBO_APP_SECRET=your_app_secret_here
WEIBO_REDIRECT_URI=http://localhost:8000/callback
WEIBO_ACCESS_TOKEN=your_access_token_here
# Keep disabled until the app permission and token have been verified.
WEIBO_PUBLISH_ENABLED=False
WEIBO_REQUEST_TIMEOUT_SECONDS=20
WEIBO_MAX_IMAGE_SIZE_MB=20

# AI Image Generation API
# Choose one based on your preference
OPENAI_API_KEY=your_openai_key_here
# STABILITY_API_KEY=your_stability_key_here

# Application Settings
APP_NAME=Weibo Daily Sentence
APP_VERSION=1.0.0
DEBUG=True
LOG_LEVEL=INFO

# Paths
# Local development (Windows):
# SENTENCE_FILE_PATH=D:/university/Pudow/onesentence-oneday/sentence.md
# LOGO_DIR_PATH=D:/university/Pudow/onesentence-oneday/logo
# OUTPUT_DIR_PATH=D:/university/Pudow/onesentence-oneday/data/images
# Zeabur deployment (Linux container):
SENTENCE_FILE_PATH=/app/sentence.md
LOGO_DIR_PATH=/app/logo
OUTPUT_DIR_PATH=/app/data/images

# Content Settings
DAILY_PUBLISH_TIME=08:00
CONTENT_POOL_WARNING_THRESHOLD=5
DUPLICATE_CHECK_DAYS=30

# Image Settings
IMAGE_WIDTH=1080
IMAGE_HEIGHT=1080
LOGO_SIZE_RATIO=0.13
LOGO_MARGIN=20
BRIGHTNESS_THRESHOLD=128
